# ═══════════════════════════════════════════════
#  CONFIGURAÇÕES DE REDE - Ficha de Controle
#  Copie para .env e preencha os valores
# ═══════════════════════════════════════════════

VITE_APP_HOST=0.0.0.0
VITE_APP_PORT=5173
VITE_APP_DOMAIN=localhost
VITE_APP_PROTOCOL=http
VITE_APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_DISABLE_DEVTOOLS=true
VITE_RESTRICT_INTERNAL_NETWORK=true
VITE_APP_NAME=Ficha de Controle – IndusPower
VITE_APP_VERSION=1.0.0

# ─── Banco de Dados (futuro) ───
# VITE_API_BASE_URL=http://localhost:3001/api
# VITE_DB_PROXY_ENABLED=false

# ─── Segurança Extrema (Plugin Disable-Devtools) ───
VITE_DEVTOOLS_MD5=
VITE_DEVTOOLS_URL=
VITE_DISABLE_MENU=true
VITE_DISABLE_SELECT=true
VITE_DISABLE_COPY=true
VITE_DISABLE_CUT=true
VITE_DISABLE_PASTE=true

# ─── Cabeçalhos de Segurança ───
VITE_SECURITY_HSTS=max-age=31536000; includeSubDomains; preload
VITE_SECURITY_NO_SNIFF=nosniff
VITE_SECURITY_FRAME_OPTIONS=DENY
VITE_SECURITY_XSS_PROTECTION=1; mode=block
VITE_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
VITE_SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()
